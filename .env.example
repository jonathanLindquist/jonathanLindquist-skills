# Local machine configuration for setup-project-workflow.
# Copy this file to .env and fill in the required values before running setup.
# Do not commit .env. It contains machine-specific paths.

# setup-project-workflow: root path to the Obsidian vault that should contain this project's Kanban board.
# Use $HOME, ${HOME}, ~, or another local-only path. Do not commit actual vault roots.
PROJECT_WORKFLOW_OBSIDIAN_VAULT=
