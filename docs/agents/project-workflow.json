{
  "provider": "obsidian-kanban",
  "vaultEnvVar": "PROJECT_WORKFLOW_OBSIDIAN_VAULT",
  "boardPathStrategy": "home-relative-project-path",
  "kanbanTemplatePath": "docs/agents/kanban-template.md",
  "planDir": "docs/plans",
